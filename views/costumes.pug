extends layout

block content
  h1= title
  button.btn(class="btn-primary ml-1", onclick="dispatch('/costumes/create')") Create
  - let items = results;
  div(class="container-fluid")
    div(class="row m-1")
      each item in items
        - let destinationupdate = `dispatch(\"/costumes/update?id=${item._id}\")`
        - let destinationdetail = `dispatch(\"/costumes/detail?id=${item._id}\")`
        - let destinationdelete = `dispatch(\"/costumes/delete?id=${item._id}\")`
        div(class="row-sm-2", class="m-1") 
          | Item #{item.costume_type}(#{item.size}) is #{item.cost}
          button.btn(class="btn-primary ml-1", onclick=destinationdetail) Detail
          button.btn(class="btn-primary ml-1", onclick=destinationupdate) Update
          button.btn(class="btn-primary ml-1", onclick=destinationdelete) Delete

  script.
    function dispatch(path){
      window.location.href=path
    }